# Minimal local bootstrap example
XYN_ENV=local
XYN_AUTH_MODE=simple

# Artifact distribution
XYN_ARTIFACT_REGISTRY=public.ecr.aws/i0h0h0n4/xyn/artifacts
# XYN_ARTIFACT_REGISTRY_SLUG=default-registry
# XYN_ARTIFACT_CHANNEL=dev
# XYN_WORKSPACE_SLUG=default
# XYN_UI_IMAGE=public.ecr.aws/i0h0h0n4/xyn/artifacts/xyn-ui:dev
# XYN_API_IMAGE=public.ecr.aws/i0h0h0n4/xyn/artifacts/xyn-api:dev

# Optional developer overrides
# XYN_LOCAL_API_CONTEXT=/path/to/xyn-api
# XYN_LOCAL_UI_CONTEXT=/path/to/xyn-ui

# AI provider key (minimum requirement)
XYN_OPENAI_API_KEY=your_key_here
# XYN_GEMINI_API_KEY=
# XYN_ANTHROPIC_API_KEY=

# Optional
XYN_AI_PROVIDER=
XYN_AI_MODEL=gpt-5-mini
# XYN_AI_DISABLED=true

XYN_API_BASE_URL=http://localhost:8000
XYN_KERNEL_WORKSPACE_ID=
XYN_KERNEL_MANIFEST_ROOTS=/home/ubuntu/src
