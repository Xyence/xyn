{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xyn.local/schemas/appspec_v0.schema.json",
  "title": "Xyn AppSpec v0",
  "type": "object",
  "required": [
    "schema_version",
    "app_slug",
    "title",
    "workspace_id",
    "services",
    "data",
    "reports"
  ],
  "properties": {
    "schema_version": {
      "const": "xyn.appspec.v0"
    },
    "app_slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "image",
          "env",
          "ports",
          "depends_on"
        ],
        "properties": {
          "name": {"type": "string"},
          "image": {"type": "string"},
          "env": {"type": "object"},
          "ports": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["container", "host", "protocol"],
              "properties": {
                "container": {"type": "integer", "minimum": 1, "maximum": 65535},
                "host": {"type": "integer", "minimum": 0, "maximum": 65535},
                "protocol": {"type": "string", "enum": ["tcp", "udp"]}
              }
            }
          },
          "depends_on": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "ingress": {
      "type": "object"
    },
    "data": {
      "type": "object",
      "required": ["postgres"],
      "properties": {
        "postgres": {
          "type": "object"
        }
      }
    },
    "reports": {
      "type": "array",
      "items": {"type": "string"}
    },
    "requires_primitives": {
      "type": "array",
      "items": {"type": "string"}
    },
    "entity_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {"type": "string"},
          "singular_label": {"type": "string"},
          "plural_label": {"type": "string"},
          "collection_path": {"type": "string"},
          "item_path_template": {"type": "string"},
          "operations": {"type": "object"},
          "presentation": {"type": "object"},
          "validation": {"type": "object"},
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "type": {"type": "string"},
                "required": {"type": "boolean"},
                "readable": {"type": "boolean"},
                "writable": {"type": "boolean"},
                "identity": {"type": "boolean"},
                "nullable": {"type": "boolean"},
                "default": {},
                "references_entity": {"type": "string"},
                "references_field": {"type": "string"},
                "options": {"type": "array", "items": {"type": "string"}},
                "relation": {
                  "type": "object",
                  "properties": {
                    "kind": {"type": "string"},
                    "relation_kind": {"type": "string"},
                    "related_entity": {"type": "string"},
                    "target_entity": {"type": "string"},
                    "source_field": {"type": "string"},
                    "field": {"type": "string"},
                    "target_field": {"type": "string"},
                    "required": {"type": "boolean"}
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {"type": "string"},
                "relation_kind": {"type": "string"},
                "related_entity": {"type": "string"},
                "target_entity": {"type": "string"},
                "source_field": {"type": "string"},
                "field": {"type": "string"},
                "target_field": {"type": "string"},
                "required": {"type": "boolean"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  }
}
