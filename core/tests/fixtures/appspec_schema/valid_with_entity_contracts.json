{
  "schema_version": "xyn.appspec.v0",
  "app_slug": "contracts-app",
  "title": "Contracts App",
  "workspace_id": "22222222-2222-2222-2222-222222222222",
  "services": [
    {
      "name": "contracts-api",
      "image": "xyn-api:latest",
      "env": {},
      "ports": [{"container": 8080, "host": 0, "protocol": "tcp"}],
      "depends_on": ["contracts-db"]
    }
  ],
  "data": {"postgres": {}},
  "reports": ["polls_by_status"],
  "entity_contracts": [
    {
      "key": "polls",
      "singular_label": "poll",
      "plural_label": "polls",
      "collection_path": "/polls",
      "item_path_template": "/polls/{id}",
      "fields": [
        {"name": "id", "type": "uuid", "required": true},
        {"name": "title", "type": "string", "required": true},
        {"name": "status", "type": "string", "options": ["draft", "open", "closed"]}
      ],
      "relationships": [],
      "operations": {
        "list": {"declared": true, "method": "GET", "path": "/polls"}
      },
      "presentation": {"title_field": "title"},
      "validation": {"required_on_create": ["workspace_id", "title"]}
    }
  ]
}
